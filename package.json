{
  "name": "showy",
  "displayName": "Showy",
  "description": "Interactive project visualizer with dependency graphs, circular dependency detection, and git insights.",
  "version": "0.2.0",
  "publisher": "omob-publish",
  "license": "MIT",
  "icon": "media/showy-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/omob2022-commits/showy.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "tree",
    "dependency graph",
    "visualization",
    "project map",
    "dependencies",
    "circular dependencies",
    "file explorer",
    "graph",
    "d3"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "showy.openProjectMap",
        "title": "Showy: Open Project Map",
        "icon": "$(graph)"
      },
      {
        "command": "showy.openShowySidebar",
        "title": "Showy: Reveal Sidebar",
        "icon": "$(graph)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "showySidebar",
          "title": "Showy",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "showySidebar": [
        {
          "id": "showyView",
          "name": "Showy Project Map"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "showy.openProjectMap",
          "group": "navigation",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "Showy",
      "properties": {
        "showy.showGitInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show git information (commit count, author, last modified) in node stats."
        },
        "showy.showDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Scan and show file dependencies (imports/includes) in node stats."
        },
        "showy.previewSize": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "maximum": 5000,
          "description": "Maximum number of characters to show in file preview."
        },
        "showy.showLineCount": {
          "type": "boolean",
          "default": true,
          "description": "Calculate and show line count for files."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.6.0"
  }
}
